# Example environment variables for the Cymbal Retail Agent
# Copy this file to ".env" and fill in values. Do not commit the real .env.

# Google Cloud API key used by the Gemini model (required)
GOOGLE_API_KEY=

# Stripe test secret key (optional, enables Stripe backend if present)
STRIPE_API_KEY=
# Optional: publishable key if frontend needs it
STRIPE_PUBLISHABLE_KEY=

# You can also set BUSINESS_AGENT_USE_STRIPE=1 to attempt to initialize
# Stripe without an API key (not recommended for real processing).
BUSINESS_AGENT_USE_STRIPE=0
